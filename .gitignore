*.o
*.a
*.so
*.elf
*.bin
*.img

# Python cache
__pycache__/
*.pyc
*.pyo

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
*.log
*.tmp
.DS_Store
Thumbs.db
